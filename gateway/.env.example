ENVIRONMENT=development
GATEWAY_PORT=8000
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:5173

POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@localhost:5432/rate_limiter
REDIS_URL=redis://localhost:6379/0

GATEWAY_USER_SERVICE_URL=http://localhost:8001
GATEWAY_PRODUCT_SERVICE_URL=http://localhost:8002
GATEWAY_ORDER_SERVICE_URL=http://localhost:8003

REQUEST_TIMEOUT_SECONDS=15
UPSTREAM_MAX_CONNECTIONS=1024
UPSTREAM_MAX_KEEPALIVE_CONNECTIONS=256
UPSTREAM_KEEPALIVE_EXPIRY_SECONDS=30
